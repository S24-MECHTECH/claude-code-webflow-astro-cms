---
import Layout from '../layouts/Layout.astro';
import { getCollection } from '../lib/webflow';

export async function getStaticPaths() {
  const COLLECTION_ID = '6826b5c28a9bb669ef7d7b1f';

  let posts: Awaited<ReturnType<typeof getCollection>> = [];
  try {
    posts = await getCollection(COLLECTION_ID);
  } catch (e) {
    console.error('Failed to load posts:', e);
  }

  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await Astro.compile(`
<Fragment>${post['post-body'] || '<p>No content.</p>'}</Fragment>
`);

const publishedDate = post['published-on']
  ? new Date(post['published-on']).toLocaleDateString('de-DE', {
      year: 'numeric',
      month: 'long',
      day: 'numeric',
    })
  : null;
---

<Layout title={`${post.name} | Blog`} description={post.name}>
  <article>
    <header style="margin-bottom: 2.5rem;">
      <a
        href="/"
        style="display: inline-flex; align-items: center; gap: 0.375rem; font-size: 0.875rem; color: var(--text-muted); text-decoration: none; margin-bottom: 1.5rem; transition: color 0.2s;"
      >
        ← Zurück zum Blog
      </a>
      <h1 style="font-size: 2.25rem; margin-bottom: 0.75rem; letter-spacing: -0.025em;">
        {post.name}
      </h1>
      {publishedDate && (
        <time
          datetime={post['published-on']}
          style="font-size: 0.95rem; color: var(--text-muted);"
        >
          {publishedDate}
        </time>
      )}
    </header>

    <div
      class="post-content"
      style="font-size: 1.05rem; line-height: 1.75; color: var(--text);"
    >
      <Fragment set:html={post['post-body'] || '<p>No content available.</p>'} />
    </div>
  </article>
</Layout>

<style>
  .post-content {
    word-break: break-word;
  }
  .post-content :global(h1),
  .post-content :global(h2),
  .post-content :global(h3),
  .post-content :global(h4) {
    margin-top: 2em;
    margin-bottom: 0.75em;
    letter-spacing: -0.02em;
  }
  .post-content :global(p) {
    margin-bottom: 1.25em;
  }
  .post-content :global(img) {
    max-width: 100%;
    height: auto;
    border-radius: 8px;
    margin: 1.5em 0;
  }
  .post-content :global(a) {
    color: var(--accent);
    text-decoration: underline;
    text-decoration-color: color-mix(in srgb, var(--accent) 40%, transparent);
    text-underline-offset: 3px;
  }
  .post-content :global(a:hover) {
    color: var(--accent-hover);
    text-decoration-color: var(--accent-hover);
  }
  .post-content :global(blockquote) {
    border-left: 3px solid var(--accent);
    padding-left: 1.25em;
    margin: 1.5em 0;
    color: var(--text-muted);
    font-style: italic;
  }
  .post-content :global(code) {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 4px;
    padding: 0.15em 0.4em;
    font-size: 0.875em;
    font-family: 'Courier New', monospace;
  }
  .post-content :global(pre) {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 1.25em;
    overflow-x: auto;
    margin: 1.5em 0;
  }
  .post-content :global(pre code) {
    background: none;
    border: none;
    padding: 0;
    font-size: 0.875rem;
  }
  .post-content :global(ul),
  .post-content :global(ol) {
    padding-left: 1.5em;
    margin-bottom: 1.25em;
  }
  .post-content :global(li) {
    margin-bottom: 0.4em;
  }
  .post-content :global(hr) {
    border: none;
    border-top: 1px solid var(--border);
    margin: 2em 0;
  }
</style>
