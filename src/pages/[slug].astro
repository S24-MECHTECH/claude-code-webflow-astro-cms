---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import SeoHero from '../components/SeoHero.astro';
import ContentSection from '../components/ContentSection.astro';
import FaqSection from '../components/FaqSection.astro';
import TopBanner from '../components/TopBanner.astro';
import DesignerBanner from '../components/DesignerBanner.astro';
import { getItemBySlug } from '../lib/webflow';
import { SITE_TITLE } from '../consts';

export async function getStaticPaths() {
  const { getAllItems } = await import('../lib/webflow');
  const items = getAllItems();
  return items
    .filter(item => item.slug)
    .map(item => ({
      params: { slug: item.slug },
      props: { item },
    }));
}

const { item } = Astro.props;
---

<!doctype html>
<html lang="de">
	<head>
		<BaseHead
			title={item.seoTitle || item.name || SITE_TITLE}
			description={item.seoDescription || item.description}
			image={item.ogImage || item.heroBanner}
		/>
		<meta property="og:type" content="website" />
		<meta property="og:locale" content="de_DE" />
		<meta property="og:url" content={`https://s24-mechtech.pages.dev/${item.slug}`} />
		<meta property="og:title" content={item.ogTitle || item.seoTitle || item.name} />
		<meta property="og:description" content={item.ogDescription || item.seoDescription} />
		{item.ogImage && <meta property="og:image" content={item.ogImage} />}
		<link rel="canonical" href={`https://s24-mechtech.pages.dev/${item.slug}`} />

		<!-- JSON-LD Structured Data -->
		<script type="application/ld+json" set:html={JSON.stringify({
			"@context": "https://schema.org",
			"@type": "WebPage",
			"name": item.seoTitle || item.name,
			"description": item.seoDescription || item.description,
			"url": `https://s24-mechtech.pages.dev/${item.slug}`,
			"inLanguage": "de-DE",
			"isPartOf": {
				"@type": "WebSite",
				"name": "SiliconeDolls24",
				"url": "https://s24-mechtech.pages.dev"
			},
			...(item.ogImage && {
				"image": {
					"@type": "ImageObject",
					"url": item.ogImage,
					"width": 1200,
					"height": 630
				}
			}),
			...(item.lastUpdated && {
				"dateModified": item.lastUpdated
			}),
			"publisher": {
				"@type": "Organization",
				"name": "SiliconeDolls24",
				"url": "https://www.siliconedolls24.com"
			}
		})} />

		<!-- FAQ Schema (wenn FAQ vorhanden) -->
		{item.faqSection && (
			<script type="application/ld+json" set:html={JSON.stringify({
				"@context": "https://schema.org",
				"@type": "FAQPage",
				"name": item.seoTitle || item.name,
				"mainEntity": item.faqSection.split('\n').filter(line => line.startsWith('## ')).map(q => ({
					"@type": "Question",
					"name": q.replace(/^##\s*/, '').trim(),
					"acceptedAnswer": {
						"@type": "Answer",
						"text": ""
					}
				}))
			})} />
		)}

		<!-- Breadcrumb Schema -->
		<script type="application/ld+json" set:html={JSON.stringify({
			"@context": "https://schema.org",
			"@type": "BreadcrumbList",
			"itemListElement": [
				{
					"@type": "ListItem",
					"position": 1,
					"name": "Startseite",
					"item": "https://s24-mechtech.pages.dev"
				},
				{
					"@type": "ListItem",
					"position": 2,
					"name": item.name,
					"item": `https://s24-mechtech.pages.dev/${item.slug}`
				}
			]
		})} />
	</head>
	<body>
		<TopBanner />
		<Header />
		<DesignerBanner />
		<SeoHero item={item} />
		<ContentSection item={item} />
		{item.faqSection && <FaqSection content={item.faqSection} />}
		<Footer />
	</body>
</html>
