---
// Premium Features Section - Static content
const features = [
  { icon: '🚚', title: 'Schnelle Lieferung', desc: 'Diskrete und schnelle Lieferung innerhalb von 2-4 Werktagen' },
  { icon: '📦', title: 'Diskret Verpackt', desc: 'Neutraler Versand in unauffälliger Verpackung' },
  { icon: '💎', title: 'Premium Qualität', desc: 'Hochwertige Materialien aus Deutschland' },
  { icon: '🔒', title: 'SSL Verschlüsselt', desc: 'Ihre Daten sind sicher und geschützt' },
  { icon: '⭐', title: 'Top Bewertungen', desc: '4.9/5 Sterne von 500+ Kunden' },
  { icon: '🇩🇪', title: 'Deutsche Marke', desc: 'Deutscher Kundenservice' },
];
---

<section class="features">
	<div class="container">
		<h2>Warum SiliconeDolls24?</h2>
		<p class="section-subtitle">Entdecken Sie die Vorteile unserer Premium Silikonpuppen</p>
		<div class="features-grid">
			{features.map(feature => (
				<div class="feature-card">
					<span class="feature-icon">{feature.icon}</span>
					<h3>{feature.title}</h3>
					<p>{feature.desc}</p>
				</div>
			))}
		</div>
	</div>
</section>

<style>
	.features {
		padding: 5rem 1.5rem;
		background: white;
	}
	.container {
		max-width: 1200px;
		margin: 0 auto;
	}
	h2 {
		text-align: center;
		font-size: clamp(1.8rem, 4vw, 2.5rem);
		color: rgb(var(--black));
		margin: 0 0 0.5rem 0;
	}
	.section-subtitle {
		text-align: center;
		color: rgb(var(--gray));
		margin: 0 0 3rem 0;
		font-size: 1.1rem;
	}
	.features-grid {
		display: grid;
		grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
		gap: 1.5rem;
	}
	.feature-card {
		text-align: center;
		padding: 2rem 1.5rem;
		border-radius: 16px;
		background: linear-gradient(135deg, #f8f9fa 0%, #fff 100%);
		border: 1px solid rgba(0,0,0,0.06);
		transition: transform 0.2s, box-shadow 0.2s;
	}
	.feature-card:hover {
		transform: translateY(-4px);
		box-shadow: 0 8px 30px rgba(0,0,0,0.08);
	}
	.feature-icon {
		font-size: 2.5rem;
		display: block;
		margin-bottom: 1rem;
	}
	.feature-card h3 {
		font-size: 1.15rem;
		margin: 0 0 0.5rem 0;
		color: rgb(var(--black));
	}
	.feature-card p {
		margin: 0;
		font-size: 0.95rem;
		color: rgb(var(--gray));
		line-height: 1.5;
	}
</style>
