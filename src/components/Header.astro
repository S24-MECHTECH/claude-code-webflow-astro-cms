---
import { SITE_TITLE, SITE_URL, SITE_LOGO_URL } from '../consts';
---

<header>
	<nav>
		<div class="nav-actions">
			<a href="https://siliconedolls24.com" class="cta-nav">Jetzt Kaufen</a>
		</div>
		<div class="nav-links">
			<a href="/" class="nav-link">Startseite</a>
			<a href="/s24-seo-cms" class="nav-link">Shop</a>
			<a href="/s24-seo-cms" class="nav-link">Premium</a>
			<a href="/s24-seo-cms" class="nav-link">Kontakt</a>
		</div>
		<a href="/" class="logo-link">
			{SITE_LOGO_URL && (
				<img src={SITE_LOGO_URL} alt={SITE_TITLE} class="logo-img" />
			)}
			<span class="logo-text">{SITE_TITLE}</span>
		</a>
	</nav>
</header>

<style>
	header {
		background: white;
		border-bottom: 1px solid rgba(0,0,0,0.08);
		position: sticky;
		top: 0;
		z-index: 100;
		box-shadow: 0 2px 12px rgba(0,0,0,0.06);
	}
	nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
		max-width: 1200px;
		margin: 0 auto;
		padding: 0 1.5rem;
		height: 68px;
		gap: 1rem;
	}
	.logo-link {
		display: flex;
		align-items: center;
		text-decoration: none;
		gap: 0.75rem;
		flex-shrink: 0;
	}
	.logo-img {
		height: 48px;
		width: auto;
		max-width: 180px;
		object-fit: contain;
	}
	.logo-text {
		font-weight: 800;
		font-size: 1.1rem;
		color: #1a1a2e;
		letter-spacing: -0.01em;
	}
	.nav-links {
		display: flex;
		gap: 0.25rem;
		flex: 1;
		justify-content: center;
	}
	.nav-link {
		padding: 0.5rem 1rem;
		color: rgb(34, 41, 57);
		text-decoration: none;
		font-weight: 600;
		font-size: 0.95rem;
		border-radius: 8px;
		transition: background 0.2s, color 0.2s;
	}
	.nav-link:hover {
		background: rgba(233,69,96,0.08);
		color: #e94560;
	}
	.nav-actions {
		flex-shrink: 0;
	}
	.cta-nav {
		display: inline-block;
		background: linear-gradient(135deg, #e94560 0%, #c23152 100%);
		color: white;
		padding: 0.6rem 1.5rem;
		border-radius: 50px;
		font-weight: 700;
		font-size: 0.9rem;
		text-decoration: none;
		transition: transform 0.2s, box-shadow 0.2s;
		box-shadow: 0 2px 12px rgba(233,69,96,0.35);
	}
	.cta-nav:hover {
		transform: translateY(-1px);
		box-shadow: 0 4px 16px rgba(233,69,96,0.45);
		color: white;
	}
	@media (max-width: 768px) {
		.nav-links { display: none; }
		.logo-text { display: none; }
		nav { height: 60px; }
		.logo-img { height: 38px; }
	}
</style>
